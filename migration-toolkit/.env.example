# =============================================================================
# ezLegal.ai Migration Toolkit - Environment Configuration
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in ALL values below with your actual credentials
# 3. NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# SOURCE: Legacy MySQL Database (LegalBreeze)
# -----------------------------------------------------------------------------
# Production MySQL on EC2 (100.21.9.87)
MYSQL_HOST=100.21.9.87
MYSQL_PORT=3306
MYSQL_USER=legalbre_admin
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE_MAIN=legalbre_main
MYSQL_DATABASE_WP=legalbre_wp
MYSQL_DATABASE_API=legalbre_api

# SSH Tunnel (if MySQL is not directly accessible)
SSH_HOST=100.21.9.87
SSH_USER=ec2-user
SSH_KEY_PATH=/path/to/your/ec2-key.pem

# -----------------------------------------------------------------------------
# TARGET: Supabase Database
# -----------------------------------------------------------------------------
# Get these from your Supabase project dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct database connection (for bulk imports)
# Get this from Supabase dashboard > Settings > Database > Connection string
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# LEGACY AI: Python Chatbot Server (52.35.244.130)
# -----------------------------------------------------------------------------
# Location of FAISS index files for embedding migration
FAISS_INDEX_PATH=/var/www/chatbot/indexes
FAISS_SSH_HOST=52.35.244.130
FAISS_SSH_USER=ec2-user
FAISS_SSH_KEY_PATH=/path/to/chatbot-key.pem

# -----------------------------------------------------------------------------
# AI: OpenAI Configuration (for re-embedding if needed)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# MIGRATION SETTINGS
# -----------------------------------------------------------------------------
# Batch size for database operations
BATCH_SIZE=100

# Enable dry run mode (validates without writing)
DRY_RUN=false

# Enable verbose logging
VERBOSE=true

# Backup directory for extracted data
BACKUP_DIR=./backups

# Log file location
LOG_FILE=./logs/migration.log
