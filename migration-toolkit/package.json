{
  "name": "ezlegal-migration-toolkit",
  "version": "1.0.0",
  "description": "Complete migration toolkit for ezLegal.ai - MySQL to Supabase migration",
  "type": "module",
  "scripts": {
    "extract": "node scripts/extract-mysql.js",
    "transform": "node scripts/transform-data.js",
    "import": "node scripts/import-supabase.js",
    "migrate:users": "node scripts/migrate-users.js",
    "migrate:lawyers": "node scripts/migrate-lawyers.js",
    "migrate:cases": "node scripts/migrate-cases.js",
    "migrate:documents": "node scripts/migrate-documents.js",
    "migrate:embeddings": "node scripts/migrate-embeddings.js",
    "migrate:all": "npm run extract && npm run transform && npm run import",
    "validate": "node scripts/validate-migration.js",
    "validate:counts": "node scripts/validate-counts.js",
    "validate:integrity": "node scripts/validate-integrity.js",
    "rollback": "node scripts/rollback.js",
    "test:connection": "node scripts/test-connections.js",
    "generate:report": "node scripts/generate-report.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "mysql2": "^3.9.0",
    "dotenv": "^16.4.0",
    "ora": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.4.0",
    "uuid": "^9.0.0",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
