# ============================================================
# EZLegal.ai - Environment Variables
# ============================================================
# Copy this file to .env and fill in your project values.
# Variables prefixed with VITE_ are exposed to the browser.
# NEVER put private/secret keys in VITE_ variables.
# ============================================================

# --- Frontend (safe for browser) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_LEAD_ENDPOINT=
VITE_DEMO_URL=
VITE_CONTACT_EMAIL=hello@ezlegal.ai
VITE_GA_MEASUREMENT_ID=

# --- Server-side only (Edge Functions) ---
# These are configured as Supabase Edge Function secrets.
# They are NOT used in the frontend and must NEVER be prefixed with VITE_.
#
# SUPABASE_SERVICE_ROLE_KEY=<set via Supabase secrets>
# OPENAI_API_KEY=<set via Supabase secrets>
# STRIPE_SECRET_KEY=<set via Supabase secrets>
# STRIPE_WEBHOOK_SECRET=<set via Supabase secrets>
# RESEND_API_KEY=<set via Supabase secrets>
# LEGALBREEZE_API_URL=<set via Supabase secrets>
# LEGALBREEZE_PYTHON_URL=<set via Supabase secrets>
# CRON_SECRET=<set via Supabase secrets>
